{
  "file_types": {
    "ini": [
      ".npmrc"
    ],
    "tailwindcss": [
      "*.css"
    ],
    "env": [
      ".env",
      ".env.*"
    ]
  },
  "hidden_files": [
    "**/.wrangler",
    "**/.agents"
  ],
  "file_scan_exclusions": [
    ".git",
    "**/.vscode",
    "**/.agents",
    "**/.wrangler"
  ],
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "classFunctions": [
          "cva",
          "cx",
          "twMerge",
          "class",
          "tw\\.[a-z-]+",
          "cn",
          "clsx"
        ],
        "experimental": {
          "classRegex": [
            "(?:cls|class|className|classList)\\s\\:\\=\\s\"([^\"]*)"
          ]
        }
      }
    },
    "oxlint": {
      "initialization_options": {
        "settings": {
          "configPath": null,
          "run": "onType",
          "disableNestedConfig": false,
          "fixKind": "safe_fix",
          "typeAware": true,
          "unusedDisableDirectives": "deny"
        }
      }
    },
    "oxfmt": {
      "initialization_options": {
        "settings": {
          "run": "onSave",
          "fmt.configPath": null
        }
      }
    }
  },
  "languages": {
    "CSS": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "HTML": {
      "format_on_save": "on",
      "language_servers": [
        "oxc"
      ],
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "MDX": {
      "language_servers": [
        "typescript-language-server",
        "oxfmt",
        "oxlint"
      ],
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "Markdown": {
      "language_servers": [
        "typescript-language-server",
        "oxfmt",
        "oxlint",
        "markdown-oxide"
      ],
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "JSON": {
      "format_on_save": "on",
      "language_servers": [
        "json-language-server",
        "oxfmt",
        "oxlint"
      ],
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "JSONC": {
      "format_on_save": "on",
      "language_servers": [
        "json-language-server",
        "oxfmt",
        "oxlint"
      ],
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "JSDoc": {
      "language_servers": [
        "typescript-language-server",
        "oxfmt",
        "oxlint"
      ],
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "TSX": {
      "format_on_save": "on",
      "language_servers": [
        "typescript-language-server",
        "oxfmt",
        "oxlint"
      ],
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "JavaScript": {
      "format_on_save": "on",
      "language_servers": [
        "typescript-language-server",
        "oxfmt",
        "oxlint"
      ],
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        },
        {
          "code_action": "source.fixAll.oxc"
        }
      ]
    },
    "TypeScript": {
      "format_on_save": "on",
      "language_servers": [
        "typescript-language-server",
        "oxfmt",
        "oxlint"
      ],
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "YAML": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    }
  }
}
