{
  "name": "h0n0",
  "version": "0.0.0",
  "license": "MIT",
  "repository": "github:o-az/h0n0",
  "type": "module",
  "imports": {
    "#*": "./src/*",
    "#package.json": "./package.json",
    "#wrangler.json": "./wrangler.json"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build --mode='production' --config='vite.config.ts'",
    "preview": "vite preview",
    "test": "vitest --run",
    "format": "oxfmt --config='oxfmt.config.ts' --write",
    "lint": "oxlint --config='oxlint.config.ts' --type-aware --type-check --fix-dangerously",
    "check": "bun format && bun lint",
    "deploy": "NODE_ENV='production' wrangler deploy",
    "check:types": "bun tsgo --project tsconfig.json --noEmit",
    "types": "wrangler types --env-file='.env.example'",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@std/ulid": "npm:@jsr/std__ulid",
    "hono": "^4.12.16",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.35.0",
    "@cloudflare/vitest-pool-workers": "^0.15.2",
    "@cloudflare/workers-types": "^4.20260504.1",
    "@j178/prek": "^0.3.11",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "^7.0.0-dev.20260503.1",
    "@vitejs/devtools": "^0.1.18",
    "@vitest/ui": "^4.1.5",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wrangler": "^4.87.0"
  },
  "packageManager": "bun@1.3.13",
  "simple-git-hooks": {
    "pre-commit": "bun prek run --all-files --config='.github/.pre-commit.yml'"
  }
}
